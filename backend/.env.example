# ==========================================
# MC-Repo
# ==========================================

# Server Network Settings
PORT=5000
NODE_ENV=development # Options: development, production, test
LOG_LEVEL=info # Options: debug, info, warn, error

# Relational Database Connection (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/db_name?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/db_name?schema=public"

# Redis Cache and Message Broker (BullMQ)
REDIS_URL="redis://localhost:6379"

# Supabase Platform Authentication & Storage Credentials
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-admin-bypass-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-for-decoding"

# Security Configuration Constants
BCRYPT_ROUNDS=12
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
JWT_EXPIRE_IN="1h"
