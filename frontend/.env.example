# BCD-FSS Frontend Environment Configuration

# Application Identity
VITE_APP_NAME="BCD-FSS Portal"

# API & Real-time Server Connections
# In development, these route via Vite reverse proxy.
# In production, they should point directly to the load balancer / Nginx gateway.
VITE_API_URL="/api"
VITE_SOCKET_URL="/"

# Supabase Auth Provider Connections
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-public-key"
